@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(spdlog CONFIG REQUIRED)

if(@COMMONLIBF4_ENABLE_JSON@)
    find_dependency(glaze CONFIG REQUIRED)
endif()

if(@COMMONLIBF4_ENABLE_TOML@)
    find_dependency(toml11 CONFIG REQUIRED)
endif()

if(@COMMONLIBF4_ENABLE_XBYAK@)
    find_dependency(xbyak CONFIG REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/CommonLibF4Targets.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/CommonLibF4Plugin.cmake")

check_required_components(CommonLibF4)
